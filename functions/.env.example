# Kommo OAuth — set for local `firebase emulators` / CI; in production use
# Firebase Functions secrets or parameterized configuration (do not commit real values).
#
# Redirect URI (register the SAME string in the Kommo integration settings):
#   https://<your-host>/<optional-base-path>/#/kommo-oauth-callback
# Example (GitHub Pages + this repo homepage):
#   https://skglobalservices.github.io/OopsOutSepticTankYServicesAruba/#/kommo-oauth-callback
# No trailing slash inconsistencies: match origin + pathname + "/#/kommo-oauth-callback" exactly.
#
KOMMO_CLIENT_ID=your_kommo_integration_client_id
KOMMO_CLIENT_SECRET=your_kommo_integration_client_secret
# Subdomain only (e.g. "yoursubdomain" for yoursubdomain.kommo.com) — required for CRM API (talks, notes)
KOMMO_DOMAIN=yoursubdomain

# --- Chats API (Amojo) — real WhatsApp / Inbox messages ---
# Obtained when connecting your custom/integration channel in Kommo (see Kommo Chats docs).
# POST https://amojo.kommo.com/v2/origin/custom/{scope_id}
KOMMO_CHANNEL_SECRET=your_channel_secret
KOMMO_SCOPE_ID=your_scope_id
# account_id returned by the channel connect flow (numeric string)
KOMMO_AMOJO_ACCOUNT_ID=your_amojo_account_id
# Sender identity in the payload (use a stable id; adjust if Kommo requires a manager id)
KOMMO_AMOJO_SENDER_ID=integration
KOMMO_AMOJO_SENDER_NAME=Oops

# If Amojo returns 401/403, try base64 MD5 for Content-MD5 header (default is hex)
# KOMMO_AMOJO_MD5_MODE=base64

# Fallback: send as CRM lead note instead of real channel message (dev / emergency only)
# KOMMO_SEND_FALLBACK_NOTES=true

# Default country code for matching RTDB telefono* with Kommo numbers (Aruba = 297)
# KOMMO_DEFAULT_COUNTRY_CODE=297
